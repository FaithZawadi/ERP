{
  "name": "qsl-erp",
  "version": "2.0.0",
  "description": "Qalibrated Systems Limited — Enterprise Resource Planning System",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "scheduler": "node src/lib/scheduler.js",
    "scheduler:now": "node src/lib/scheduler.js --run-now",
    "db:init": "node database/init.js",
    "db:migrate-v4": "node database/migrate-v4.js",
    "db:migrate-v5": "node database/migrate-v5.js",
    "db:migrate-v6": "node database/migrate-v6.js",
    "db:migrate-v7": "node database/migrate-v7.js",
    "db:migrate-v4-v7": "node database/migrate-v4-through-v7-consolidated.js",
    "db:migrate-v8": "node database/migrate-v8.js",
    "db:migrate-v9": "node database/migrate-v9.js",
    "db:migrate-v10": "node database/migrate-v10.js",
    "db:migrate-v11": "node database/migrate-v11.js",
    "db:migrate-v12": "node database/migrate-v12.js",
    "db:migrate-v13": "node database/migrate-v13.js",
    "db:migrate-v14": "node database/migrate-v14.js",
    "db:seed-demo-roles": "node database/seed-demo-roles.js",
    "db:seed": "node database/seed.js",
    "db:seed-coa": "node database/seed-coa.js",
    "db:pg-generate-schema": "node database/generate-pg-schema.js",
    "db:pg-setup": "node database/setup-postgres.js",
    "db:backup": "node -e \"require('./src/lib/scheduler').runDatabaseBackup()\"",
    "db:reset": "rm -f database/qsl_erp.db && npm run db:init && npm run db:seed && npm run db:seed-coa",
    "scheduler:start": "node src/lib/scheduler.js",
    "jobs:imprest": "node -e \"require('./src/lib/scheduler').runImprestOverdue()\"",
    "jobs:compliance": "node -e \"require('./src/lib/scheduler').runComplianceAlerts()\"",
    "jobs:fleet": "node -e \"require('./src/lib/scheduler').runFleetAlerts()\"",
    "email:test": "node -e \"require('./src/lib/email').send({to:process.env.SMTP_USER||'test@qalibrated.co.ke',subject:'QSL ERP Test Email',html:'<b>QSL ERP is configured correctly.</b>'}).then(r=>console.log('Email result:',r))\"",
    "mfa:test": "node -e \"const m=require('./src/lib/mfa');m.generateMFASecret('test@qalibrated.co.ke','Test').then(r=>{console.log('Secret:',r.secret.slice(0,10)+'...');console.log('Token:',m.generateCurrentTOTP(r.secret));console.log('Valid:',m.verifyTOTP(r.secret,m.generateCurrentTOTP(r.secret)));})\""
  },
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.0.0",
    "exceljs": "^4.4.0",
    "jsonwebtoken": "^9.0.0",
    "next": "^14.0.0",
    "node-cron": "^4.0.0",
    "nodemailer": "^9.0.0",
    "pdfkit": "^0.15.2",
    "pg": "^8.22.0",
    "qrcode": "^1.5.4",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "recharts": "^3.8.1",
    "speakeasy": "^2.0.0",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  }
}
