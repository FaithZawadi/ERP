# Dependencies
node_modules/

# Next.js build output
.next/
out/
build/

# Runtime database (generated via npm run db:init && db:seed)
database/*.db
database/*.db-journal
database/*.sqlite
# ...but DO ship the known-good seed template used to bootstrap a fresh host
!database/seed-template.db

# Uploaded files (runtime user content)
uploads/**/*
!uploads/**/.gitkeep

# Logs
logs/*
!logs/.gitkeep
*.log
npm-debug.log*

# Environment / secrets — keep only the example
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
