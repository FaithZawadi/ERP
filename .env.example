# QSL ERP — Environment Variables
# Copy this file to .env.local and fill in your values

# ── APPLICATION ──────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_PORT=4000
JWT_SECRET=qsl-erp-jwt-secret-change-in-production-min-32-chars
JWT_EXPIRES_IN=8h
SESSION_SECRET=qsl-erp-session-secret-change-in-production

# ── DATABASE ─────────────────────────────────────────────────────
# For production: use PostgreSQL
DATABASE_URL=postgresql://qsl_user:password@localhost:5432/qsl_erp
# For development: SQLite (auto-created)
DB_FILE=./database/qsl_erp.db

# ── KRA eTIMS INTEGRATION ────────────────────────────────────────
# Kenya Revenue Authority - Electronic Tax Invoice Management System
KRA_ETIMS_URL=https://etims-api.kra.go.ke/etims-api
KRA_ETIMS_SANDBOX_URL=https://etims-sbx-api.kra.go.ke/etims-api
KRA_ETIMS_PIN=P000000001K          # QSL KRA PIN
KRA_ETIMS_BRANCH_ID=00             # Branch ID (00 = HQ)
KRA_ETIMS_DEVICE_ID=               # VSCU/OSCU Device ID from KRA
KRA_ETIMS_KEY=                     # API Key from KRA eTIMS portal
KRA_ETIMS_ENV=sandbox              # sandbox | production

# ── PPIP / TENDER PORTAL ─────────────────────────────────────────
# Public Procurement Information Portal
PPIP_API_URL=https://tenders.go.ke/api/v1
PPIP_API_KEY=                      # Get from PPIP portal account
PPIP_ENTITY_CODE=                  # QSL entity code on PPIP

# ── MPESA / PAYMENT INTEGRATION ──────────────────────────────────
# Safaricom M-PESA Daraja API
MPESA_ENVIRONMENT=sandbox          # sandbox | production
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=                   # Paybill or Till number
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/api/integrations/mpesa/callback

# ── EMAIL (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=info@qalibrated.co.ke
SMTP_PASS=                         # App password from Google
SMTP_FROM=QSL ERP <info@qalibrated.co.ke>

# ── COMPANY SETTINGS ─────────────────────────────────────────────
COMPANY_NAME=Qalibrated Systems Limited
COMPANY_KRA_PIN=P000000001K
COMPANY_VAT_NUMBER=P000000001K
COMPANY_ADDRESS=Birdi Singh Complex, 1st Floor, Off Mombasa Road, Nairobi
COMPANY_PHONE=+254714999996
COMPANY_EMAIL=info@qalibrated.co.ke
COMPANY_WEBSITE=www.qalibrated.co.ke

# ── FILE STORAGE ─────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760             # 10MB in bytes

# ── KENYA STATUTORY RATES (update annually) ──────────────────────
VAT_RATE=0.16                      # 16%
PAYE_PERSONAL_RELIEF=28800         # Annual personal relief Kshs
NHIF_RATE=0.0275                   # 2.75% of gross (new SHIF rate)
NSSF_TIER1_LIMIT=7000              # Tier I ceiling
NSSF_TIER2_LIMIT=36000             # Tier II ceiling
NSSF_RATE=0.06                     # 6% employee + 6% employer
HOUSING_LEVY_RATE=0.015            # 1.5% of gross
WITHHOLDING_TAX_PROFESSIONAL=0.05  # 5% WHT on professional fees
WITHHOLDING_TAX_RENT=0.30          # 30% WHT on rental income

# ── BANK API (optional) ──────────────────────────────────────────
BANK_API_URL=
BANK_API_KEY=
BANK_ACCOUNT_NUMBER=

# ── SMS (Africa's Talking) ────────────────────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=QSL-ERP
